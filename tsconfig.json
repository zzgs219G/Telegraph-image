{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["astro/client", "@cloudflare/workers-types"]
  },
  "include": ["src/**/*", "functions/**/*"]
}
